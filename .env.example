# Backend runtime
# Keep this as "local" for the browser-only demo. Switch to "firebase" only after
# filling the Firebase web config and selecting a Firebase CLI project locally.
#
# Auth implication:
# - local  = passwordless on-device demo (Create account / Log in by email only).
# - firebase = real email/password Log in & Create account via Firebase Auth, with
#              email verification before learning progress is saved.
VITE_BACKEND_PROVIDER=local

# Firebase web app config
# Fill these from Firebase Console > Project settings > Your apps > Web app config.
# NOTE: these values (including the API key) are PUBLIC by design and ship in the client bundle. What
# actually protects the project from anyone reusing the key is App Check (below) + the Firestore rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase App Check (recommended for any real deploy that uses Firebase mode).
# Create a reCAPTCHA v3 site key, register it under Project settings > App Check, then ENFORCE App
# Check on Authentication, Cloud Firestore, and AI Logic in the console. Leaving the site key blank
# disables App Check (fine for local mode), so the project's backends would accept the public API key
# from anywhere — set it before exposing Firebase mode publicly.
VITE_FIREBASE_APPCHECK_SITE_KEY=
# LOCAL DEV ONLY: a debug token registered under App Check, so localhost/CI pass attestation. Never
# set this in a production build.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

# === Story Mode AI ===
# Story Mode wraps each practice question in an AI-generated adventure. Your math, answers, and
# grading ALWAYS stay local/in-code — the AI only rewrites the display text. Pick ONE option.

# Option A (LOCAL DEV ONLY): the dev server's OpenAI proxy.
# Set OPENAI_API_KEY (UNPREFIXED) and leave VITE_STORY_AI_PROVIDER blank. vite.config.ts pins
# envPrefix to VITE_ only, so an unprefixed OPENAI_API_KEY is NEVER inlined into the client bundle —
# it is read SERVER-SIDE by the dev proxy in devProxy/ (apply: 'serve'), which exists only during
# `vite dev`. A production static build has no such proxy, so for any deploy use Option B or C below.
# (Do NOT rename this to VITE_OPENAI_API_KEY to force it client-side: the secret-scan build guard in
# src/secretScan.ts rejects a VITE_* value that looks like an sk-... key, failing the build on purpose.)
OPENAI_API_KEY=
# Optional: override the OpenAI model (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# An EXPLICIT provider below WINS over Option A, so a deliberate secure setup is never downgraded:
# Option B (proxy): OpenAI behind a server proxy that holds the key. Set VITE_STORY_AI_PROVIDER=proxy
#   and VITE_STORY_AI_PROXY_URL to the proxy URL. Local dev: the Vite plugin in devProxy/ holds
#   OPENAI_API_KEY. Deploy: the Cloudflare Worker (worker/) or Cloud Function (functions/) holds the
#   key in a secret. Both enforce an origin allow-list, model allow-list, output-token cap, and
#   per-IP rate limit (worker) so the billable key can't be abused.
# Option C (firebase): Firebase AI Logic (Gemini behind App Check). Set VITE_STORY_AI_PROVIDER=firebase
#   and fill the Firebase web config + App Check above. No OpenAI key is involved, so nothing is exposed.
VITE_STORY_AI_PROVIDER=
VITE_STORY_AI_PROXY_URL=/api/story
# Optional: override the primary generation model for the proxy/firebase paths.
VITE_STORY_AI_MODEL=

# DEPRECATED — Story Mode no longer uses the Gemini Developer client key by default. Left only for
# backward compatibility: a present key is used as a LAST RESORT when no OpenAI/proxy/firebase
# provider is configured. Prefer OPENAI_API_KEY (Option A) or a secure path (B/C) above.
VITE_GEMINI_API_KEY=
