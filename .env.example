# Backend runtime
# Keep this as "local" for the browser-only demo. Switch to "firebase" only after
# filling the Firebase web config and selecting a Firebase CLI project locally.
#
# Auth implication:
# - local  = passwordless on-device demo (Create account / Log in by email only).
# - firebase = real email/password Log in & Create account via Firebase Auth, with
#              email verification before learning progress is saved.
VITE_BACKEND_PROVIDER=local

# Firebase web app config
# Fill these from Firebase Console > Project settings > Your apps > Web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# === Story Mode AI ===
# Story Mode wraps each practice question in an AI-generated adventure. Your math, answers, and
# grading ALWAYS stay local/in-code — the AI only rewrites the display text. Pick ONE option.

# Option A (DEFAULT, simplest for local dev): call OpenAI DIRECTLY from the browser.
# Just set OPENAI_API_KEY and leave VITE_STORY_AI_PROVIDER blank. vite.config.ts exposes the OPENAI_
# prefix to client code, so the app reads this key as import.meta.env.OPENAI_API_KEY and talks to
# OpenAI directly — no rename and no extra config needed. Optionally override the model.
#
# SECURITY (read this): because OPENAI_* is exposed to the client, this key is INLINED INTO THE PUBLIC
# CLIENT BUILD whenever it is set, so anyone who loads the app can read it — and an OpenAI key is
# billable. Use Option A for LOCAL DEV ONLY (ideally a restricted/low-limit key). For a public deploy
# use Option C (or Option B) so the key never ships to the browser.
OPENAI_API_KEY=
# Optional: override the OpenAI model (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# An EXPLICIT provider below WINS over Option A, so a deliberate secure setup is never downgraded:
# Option B (proxy): OpenAI behind a same-origin server proxy. Set VITE_STORY_AI_PROVIDER=proxy and
#   VITE_STORY_AI_PROXY_URL=/api/story; locally the Vite plugin in devProxy/ holds OPENAI_API_KEY and
#   forwards to OpenAI. (Note: with Option A's envPrefix, OPENAI_API_KEY is still bundled if set, so
#   for a hardened deploy prefer Option C or drop "OPENAI_" from envPrefix in vite.config.ts.)
# Option C (firebase): Firebase AI Logic (Gemini behind App Check). Set VITE_STORY_AI_PROVIDER=firebase
#   and fill the Firebase web config above. No OpenAI key is involved, so nothing is exposed.
VITE_STORY_AI_PROVIDER=
VITE_STORY_AI_PROXY_URL=/api/story
# Optional: override the primary generation model for the proxy/firebase paths.
VITE_STORY_AI_MODEL=

# DEPRECATED — Story Mode no longer uses the Gemini Developer client key by default. Left only for
# backward compatibility: a present key is used as a LAST RESORT when no OpenAI/proxy/firebase
# provider is configured. Prefer OPENAI_API_KEY (Option A) or a secure path (B/C) above.
VITE_GEMINI_API_KEY=
