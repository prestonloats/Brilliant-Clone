# Backend runtime
# Keep this as "local" for the browser-only demo. Firebase mode fails closed until
# Firebase Auth, Firestore data migration, and the app adapter are complete.
VITE_BACKEND_PROVIDER=local

# Firebase web app config
# Fill these from Firebase Console > Project settings > Your apps > Web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
