rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if owns(uid);
    }

    match /progress/{uid}/lessons/{lessonId} {
      allow read, write: if owns(uid);
    }

    match /mastery/{uid}/skills/{skillId} {
      allow read, write: if owns(uid);
    }

    match /attempts/{uid}/events/{eventId} {
      allow read, create: if owns(uid);
      allow update, delete: if false;
    }

    match /content/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
