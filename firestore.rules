rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function verifiedEmail() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function writesUserId(uid) {
      return owns(uid) && request.resource.data.userId == uid;
    }

    match /users/{uid} {
      allow read: if owns(uid);
      // Profile bootstrap is intentionally allowed before email verification so a freshly
      // created account can write its own user document immediately after sign-up.
      allow create, update: if owns(uid) && request.resource.data.id == uid;
      allow delete: if false;
    }

    match /progress/{uid}/lessons/{lessonId} {
      allow read: if owns(uid);
      // The stored lessonId must match the document path so a write cannot mislabel
      // progress for a different lesson.
      allow create, update: if writesUserId(uid) && verifiedEmail()
        && request.resource.data.lessonId == lessonId;
      allow delete: if false;
    }

    match /mastery/{uid}/skills/{skillId} {
      allow read: if owns(uid);
      // The stored skillId must match the document path so a write cannot mislabel
      // mastery for a different skill.
      allow create, update: if writesUserId(uid) && verifiedEmail()
        && request.resource.data.skillId == skillId;
      allow delete: if false;
    }

    match /attempts/{uid}/events/{eventId} {
      allow read: if owns(uid);
      allow create: if writesUserId(uid) && verifiedEmail() && request.resource.data.id == eventId;
      allow update, delete: if false;
    }

    match /story/{uid} {
      allow read: if owns(uid);
      // The parent doc holds the active-session POINTER ({ userId, activeSessionId }). Writes
      // require a verified email and a payload userId matching the path, consistent with the
      // progress/mastery write gate. (Legacy data once lived here and is migrated into /sessions.)
      allow create, update: if writesUserId(uid) && verifiedEmail();
      allow delete: if false;

      // The saved-stories LIBRARY: one whole session document per id. The stored id must match
      // the path segment so a write cannot mislabel a session (mirrors the progress/attempt
      // id guards). Owner + verified email gate every write, including delete.
      match /sessions/{sessionId} {
        allow read: if owns(uid);
        allow create, update: if writesUserId(uid) && verifiedEmail()
          && request.resource.data.id == sessionId;
        allow delete: if owns(uid) && verifiedEmail();
      }
    }

    match /content/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
