{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist-tests"
  },
  "include": [
    "src/domain.ts",
    "src/engine.ts",
    "src/engine/**/*.ts",
    "src/backend.ts",
    "src/backend/**/*.ts",
    "src/authValidation.ts",
    "src/equationLatex.ts",
    "src/firebaseConfigCore.ts",
    "src/firebaseBackendCore.ts",
    "src/content/**/*.ts",
    "tests/**/*.ts"
  ]
}
