{
  "name": "brilliant-clone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node tests/build-tests.mjs && node --test \"dist-tests/tests/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test:ci": "npm run typecheck && npm test",
    "preview": "vite preview",
    "optimize:images": "node scripts/optimize-scenery.mjs",
    "deploy": "npm run build && firebase deploy --only hosting --project starting-project-e6700"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "firebase": "^12.15.0",
    "katex": "^0.17.0",
    "openai": "^6.45.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.22.2",
    "globals": "^17.6.0",
    "sharp": "^0.35.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
